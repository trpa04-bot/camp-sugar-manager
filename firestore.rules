rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function connectionClientWritableKeysOnly() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'uid',
        'selectedCalendarId',
        'selectedCalendarName',
        'autoSyncEnabled',
        'updatedAt'
      ]);
    }

    function createConnectionClientWritableKeysOnly() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'selectedCalendarId',
        'selectedCalendarName',
        'autoSyncEnabled',
        'updatedAt'
      ]);
    }

    // Google Calendar connection and imported events are admin-only.
    match /googleCalendarConnections/{uid} {
      allow read: if isAdmin() && request.auth.uid == uid;
      allow create: if isAdmin() && request.auth.uid == uid && createConnectionClientWritableKeysOnly();
      allow update: if isAdmin() && request.auth.uid == uid && connectionClientWritableKeysOnly();
      allow delete: if false;

      match /importEvents/{eventId} {
        allow read, write: if isAdmin() && request.auth.uid == uid;
      }
    }

    // Secret/token documents are never client-readable or writable.
    match /googleCalendarSecrets/{uid} {
      allow read, write: if false;
    }

    match /googleCalendarOAuthStates/{stateId} {
      allow read, write: if false;
    }

    match /googleCalendarSyncLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // collectionGroup('guests') queries require a dedicated rule that matches
    // every possible guests subcollection path.
    match /{path=**}/guests/{guestId} {
      allow read, write: if signedIn();
    }

    // Existing app collections remain accessible to authenticated users,
    // except google calendar integration collections protected above.
    match /{collection}/{docId} {
      allow read, write: if signedIn() && !collection.matches('googleCalendar.*');

      match /{subPath=**} {
        allow read, write: if signedIn() && !collection.matches('googleCalendar.*');
      }
    }
  }
}
